#!/bin/bash

if ! docker info >/dev/null 2>&1; then
    echo "Error: Docker daemon is not running!" >&2
    exit 1
fi

if [ ! -f "Cargo.toml" ]; then
    echo "Error: No Cargo.toml found here." >&2
    exit 1
fi

binaryName=$(grep -m 1 '^name[[:space:]]*=[[:space:]]*' Cargo.toml | sed 's/.*=[[:space:]]*"\(.*\)".*/\1/')
if [ -z "$binaryName" ]; then
    echo "Error: Could not parse project name from Cargo.toml" >&2
    exit 1
fi

echo -e "\033[33mTarget Binary Detected: $binaryName\033[0m"

# Route positional subcommand arguments
action="run"
if [[ "$1" =~ ^(run|check|test|build)$ ]]; then
    action="$1"
    shift
fi

offline=false
port=0

while [[ $# -gt 0 ]]; do
    case $1 in
        -offline|--offline)
            offline=true
            shift
            ;;
        -port|--port)
            port="$2"
            shift 2
            ;;
        *)
            shift
            ;;
    esac
done

buildArgs=()
runArgs=()

if [ "$offline" = true ]; then
    echo -e "\033[35m[Mode] Strict Offline (Using local cache)...\033[0m"
    buildArgs+=("--pull=false")
    runArgs+=("--pull=never")
fi

if [ "$action" == "check" ]; then
    echo -e "\033[36mRunning 'cargo check' inside Alpine container context...\033[0m"
    buildArgs+=("--progress=plain" "-f" "-" ".")
    df="FROM rust:alpine\nWORKDIR /app\nCOPY . .\nRUN cargo check"
    echo -e "$df" | docker build "${buildArgs[@]}"
    exit $?
elif [ "$action" == "test" ]; then
    echo -e "\033[36mRunning 'cargo test' inside Alpine container context...\033[0m"
    buildArgs+=("--progress=plain" "-f" "-" ".")
    df="FROM rust:alpine\nWORKDIR /app\nCOPY . .\nRUN cargo test"
    echo -e "$df" | docker build "${buildArgs[@]}"
    exit $?
else
    buildArgs+=("--build-arg" "BIN_NAME=$binaryName" "-f" "-" "-o" "./output" ".")
    echo -e "\033[36mCompiling static Alpine binary...\033[0m"
    rm -rf ./output

    df=$(cat <<EOF
FROM rust:alpine AS builder
ARG BIN_NAME
WORKDIR /app
COPY . .
RUN cargo test
RUN cargo build --release --target x86_64-unknown-linux-musl

FROM scratch
ARG BIN_NAME
COPY --from=builder /app/target/x86_64-unknown-linux-musl/release/\$BIN_NAME /
EOF
)

    echo "$df" | docker build "${buildArgs[@]}"

    if [ $? -eq 0 ] && [ "$action" == "run" ]; then
        echo -e "\n\033[32m[Success] Static binary compiled perfectly!\033[0m"
        echo -e "\033[36mBooting your application inside Alpine environment...\033[0m"
        
        hostOutputDir=$(pwd)/output
        runArgs+=("--rm" "-it")
        
        if [ "$port" -gt 0 ]; then
            echo -e "\033[90m[Network] Exposing inbound port: $port\033[0m"
            runArgs+=("-p" "$port:$port")
        fi
        
        runArgs+=("-v" "$hostOutputDir:/app" "alpine" "/app/$binaryName")
        docker run "${runArgs[@]}"
    elif [ $? -eq 0 ]; then
        echo -e "\n\033[32m[Success] Static binary compiled and saved to ./output/$binaryName\033[0m"
    else
        echo "Error: Build execution failed." >&2
        exit 1
    fi
fi