#!/usr/bin/env bash

show_header() {
    local msg="$1"
    local color="$2"
    case "$color" in
        "green")  echo -e "\n\033[32m[alprust] $msg\033[0m" ;;
        "yellow") echo -e "\n\033[33m[alprust] $msg\033[0m" ;;
        "magenta")echo -e "\n\033[35m[alprust] $msg\033[0m" ;;
        "red")    echo -e "\n\033[31m[alprust] $msg\033[0m" ;;
        *)        echo -e "\n\033[36m[alprust] $msg\033[0m" ;;
    esac
}

action="run"
if [[ "$1" =~ ^(run|check|test|clean|build|self-update|init|help)$ ]]; then
    action="$1"
    shift
fi

if [ "$action" == "help" ]; then
    cat << 'EOF'

=======================================================================
   alprust CLI 🚀 - Ultra-lean Alpine Linux Compilation Suite
=======================================================================
Created and maintained by codesbysuman.

Usage:
  alprust [subcommand] [flags] [passthrough-cargo-options]

Subcommands:
  init      Scaffold a brand-new Rust binary workspace from scratch
  check     Verify syntax & type safety using global cached crates
  test      Run the full workspace unit test suite inside Alpine
  clean     Clear target compilation cache for the current workspace
  build     Compile and export optimized static musl binaries
  run       (Default) Build, test, and instantly execute inside sandbox
  self-update Pull the latest engine upgrades natively from GitHub
  help      Display this unified architecture help documentation

Core Tool Modifiers & Flags:
  -port <int>  Map internal container network bridges out to host OS
  -offline     Strict air-gap execution. Disconnects internet bridges
  -refresh     Safely pull the newest crate versions into the central cache
  -verbose     Stream unfiltered raw execution and compilation logs
  -ipv4        Enforce IPv4 stacks (Fixes WSL2 network freezing bugs)

=======================================================================
EOF
    exit 0
fi

if [ "$action" == "self-update" ]; then
    show_header "Updating engine source files from GitHub..." "cyan"
    SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"
    git -C "$SCRIPT_DIR" pull
    exit $?
fi

if [ "$action" == "init" ]; then
    echo -e "\033[36m\n=========================================="
    echo -e "   alprust Project Scaffolding Engine     "
    echo -e "==========================================\033[0m"
    
    if [ -f "Cargo.toml" ]; then
        read -p "[Warning] Cargo.toml already exists! Overwrite? (y/N): " choice
        if [[ ! "$choice" =~ ^[yY] ]]; then
            echo "Scaffolding aborted."
            exit 0
        fi
    fi
    
    currentFolder=$(basename "$PWD")
    
    read -p "📦 Project Name [Default: $currentFolder]: " name
    [ -z "$name" ] && name=$currentFolder
    
    read -p "🏷️ Version [Default: 0.1.0]: " version
    [ -z "$version" ] && version="0.1.0"

    read -p "🦀 Rust Edition (e.g., 2021, 2024) [Default: 2024]: " edition
    [ -z "$edition" ] && edition="2024"
    
    read -p "Target Rust Version (e.g., 1.80, or press Enter for latest Alpine): " rustVersionInput
    
    read -p "⚙️ Dependencies (comma separated, e.g., tokio@1, serde): " depsInput
    
    tomlDeps=""
    if [ ! -z "$depsInput" ]; then
        IFS=',' read -ra ADDR <<< "$depsInput"
        for dep in "${ADDR[@]}"; do
            dep=$(echo "$dep" | xargs)
            if [[ "$dep" =~ ^([^@]+)@(.+)$ ]]; then
                depName=$(echo "${BASH_REMATCH[1]}" | xargs)
                depVer=$(echo "${BASH_REMATCH[2]}" | xargs)
                tomlDeps+="    $depName = \"$depVer\"\n"
            elif [ ! -z "$dep" ]; then
                tomlDeps+="    $dep = \"*\"\n"
            fi
        done
    fi

    packageBlock="[package]\nname = \"$name\"\nversion = \"$version\"\nedition = \"$edition\""
    if [ ! -z "$rustVersionInput" ]; then
        trimmedRustVersion=$(echo "$rustVersionInput" | xargs)
        packageBlock+="\nrust-version = \"$trimmedRustVersion\""
    fi

    cat <<EOF > Cargo.toml
$(echo -e "$packageBlock")

[dependencies]
$(echo -e "$tomlDeps")
EOF

    mkdir -p src
    cat <<EOF > src/main.rs
fn main() {
    println!("Hello from alprust scaffolded project: $name (Edition $edition)!");
}
EOF

    echo -e "\n\033[32m✨ Success! Rust project '$name' scaffolded cleanly!\033[0m"
    exit 0
fi

if ! docker info >/dev/null 2>&1; then
    echo -e "\033[31m[Error] Docker daemon is not running! Initialize your engine first.\033[0m" >&2
    exit 1
fi

get_package_val() {
    local target_key="$1"
    local in_package=false
    while IFS= read -r line || [ -n "$line" ]; do
        line=$(echo "$line" | xargs 2>/dev/null)
        [[ "$line" =~ ^# ]] && continue
        if [[ "$line" =~ ^\[([^]]+)\]$ ]]; then
            if [ "${BASH_REMATCH[1]}" = "package" ]; then
                in_package=true
            else
                in_package=false
            fi
            continue
        fi
        if [ "$in_package" = true ]; then
            if [[ "$line" =~ ^${target_key}[[:space:]]*=[[:space:]]*[\"']([^\"']+)[\"'] ]]; then
                echo "${BASH_REMATCH[1]}"
                return 0
            fi
        fi
    done < Cargo.toml
    return 1
}

if [ ! -f "Cargo.toml" ]; then
    echo -e "\033[31m[Error] No Cargo.toml discovered. Ensure your execution path matches a Rust root directory!\033[0m" >&2
    exit 1
fi

binaryName=$(get_package_val "name")
if [ -z "$binaryName" ]; then
    echo -e "\033[31m[Error] Unable to isolate package structural definitions inside Cargo.toml.\033[0m" >&2
    exit 1
fi

echo -e "\033[90mTarget Workspace Detected: \033[0m\033[33m$binaryName\033[0m"

rustVersion="alpine"
parsed_ver=$(get_package_val "rust-version")
if [ ! -z "$parsed_ver" ]; then
    rustVersion="${parsed_ver}-alpine"
    echo -e "\033[90mTargeting Rust Version: \033[0m\033[33m$parsed_ver\033[0m"
fi

offline=false
ipv4=false
refresh=false
verbose=false
all=false
port=0
passthroughFlags=()

while [[ $# -gt 0 ]]; do
    case $1 in
        -offline|--offline) offline=true; shift ;;
        -ipv4|--ipv4)       ipv4=true; shift ;;
        -refresh|--refresh) refresh=true; shift ;;
        -verbose|--verbose) verbose=true; shift ;;
        -all|--all)         all=true; shift ;;
        -port|--port)       
            if [[ "$2" =~ ^[0-9]+$ ]] && [ "$2" -ge 0 ] && [ "$2" -le 65535 ]; then
                port="$2"
                shift 2
            else
                echo -e "\033[31m[Error] -port requires a valid port number (0-65535) as an argument.\033[0m" >&2
                exit 1
            fi
            ;;
        *)                  passthroughFlags+=("$1"); shift ;;
    esac
done

cargoFlagsStr="${passthroughFlags[*]}"

# Sanitize Cargo flags to prevent shell injection inside the container
if [[ "$cargoFlagsStr" =~ [;\&\|$\`><\r\n] ]]; then
    echo -e "\033[31m[Error] Invalid/dangerous characters detected in Cargo flags.\033[0m" >&2
    exit 1
fi

is_port_busy() {
    local check_port="$1"
    if command -v nc >/dev/null 2>&1; then
        nc -z -w 1 127.0.0.1 "$check_port" >/dev/null 2>&1
        return $?
    fi
    if command -v lsof >/dev/null 2>&1; then
        lsof -i :"$check_port" >/dev/null 2>&1
        return $?
    fi
    if command -v ss >/dev/null 2>&1; then
        ss -tuln | grep -q -E "[:.]$check_port([[:space:]]|$)"
        return $?
    fi
    if command -v netstat >/dev/null 2>&1; then
        netstat -an | grep -q -E "[:.]$check_port([[:space:]]|$)"
        return $?
    fi
    return 1
}

if [ "$port" -gt 0 ] && [ "$action" == "run" ]; then
    originalPort=$port
    while is_port_busy "$port"; do
        port=$((port + 1))
    done
    if [ "$port" -ne "$originalPort" ]; then
        echo -e "\033[33m[Warning] Port $originalPort is currently busy! Auto-shifting link to open slot: $port\033[0m"
    fi
fi

# Configure BuildKit streaming modes. We always use "plain" to capture detailed compiler logs in the background,
# but we control the visibility dynamically depending on verbosity settings.
buildArgs=("--progress=plain")
runArgs=()

if [ "$offline" = true ]; then
    show_header "Strict Air-Gap Mode Active. Virtual networks severed." "magenta"
    buildArgs+=("--network" "none" "--pull=false")
    runArgs+=("--pull=never")
fi

if [ "$ipv4" = true ]; then
    show_header "Enforcing defensive IPv4 host mapping fallback layers..." "cyan"
    buildArgs+=("--network" "host")
    runArgs+=("--sysctl" "net.ipv6.conf.all.disable_ipv6=1")
fi

cacheBypass=$(date +%s%N 2>/dev/null || date +%s)
buildArgs+=("--build-arg" "CARGO_FLAGS=$cargoFlagsStr" "--build-arg" "CACHE_BYPASS=$cacheBypass")
if [ "$refresh" = true ]; then
    show_header "Atomic refresh triggered. Scanning upstream for newer package variations..." "yellow"
    buildArgs+=("--build-arg" "REFRESH_CACHE=true")
else
    buildArgs+=("--build-arg" "REFRESH_CACHE=false")
fi

cacheMounts="--mount=type=cache,id=alprust-target-$binaryName,target=/app/target --mount=type=cache,id=alprust-registry-db,target=/usr/local/cargo/registry/db --mount=type=cache,id=alprust-registry-cache,target=/usr/local/cargo/registry/cache --mount=type=cache,id=alprust-registry-index,target=/usr/local/cargo/registry/index --mount=type=cache,id=alprust-registry-src,target=/usr/local/cargo/registry/src --mount=type=cache,id=alprust-git-db,target=/usr/local/cargo/git/db --mount=type=cache,id=alprust-git-checkouts,target=/usr/local/cargo/git/checkouts"

cacheHeader="FROM rust:$rustVersion AS base\nARG CARGO_FLAGS\nARG REFRESH_CACHE=false\nARG CACHE_BYPASS\nWORKDIR /app\nCOPY . .\nRUN echo \$CACHE_BYPASS > /dev/null\nRUN $cacheMounts if [ \"\$REFRESH_CACHE\" = \"true\" ]; then cargo update; fi"

execute_build_with_ticker() {
    local df_content="$1"
    shift
    local args=("${@}")

    if [ "$verbose" = true ]; then
        echo -e "$df_content" | docker build "${args[@]}"
        return $?
    fi

    # Create temporary log file for capturing failures cleanly
    local log_file=$(mktemp)
    echo -e "$df_content" | docker build "${args[@]}" > "$log_file" 2>&1 &
    local pid=$!
    
    local start_time=$(date +%s)
    while kill -0 $pid 2>/dev/null; do
        local current_time=$(date +%s)
        local elapsed=$((current_time - start_time))
        printf "\r\033[36m[alprust] Processing compilation asset layers... (%02ds)\033[0m" $elapsed
        sleep 0.2
    done
    wait $pid
    local status=$?
    printf "\r\033[36m[alprust] Processing compilation asset layers... Done!       \033[0m\n"
    
    if [ $status -ne 0 ]; then
        echo -e "\033[31m[alprust] 🔥 Build failure detected inside the container\033[0m"
        
        if [ "$verbose" = false ] && [ -f "$log_file" ]; then
            # Parse and clean output lines
            has_compiler_output=false
            compiled_logs=""
            
            while IFS= read -r line; do
                # Skip standard Docker/BuildKit setup noise
                if [[ "$line" =~ ^#[0-9]+[[:space:]]+(DONE|CACHED|\[internal\]|resolve|transferring|export|FROM|WORKDIR|COPY|RUN|ERROR:|building\ with) ]]; then continue; fi
                if [[ "$line" =~ ^#[0-9]+[[:space:]]+ERROR: ]]; then continue; fi
                if [[ "$line" =~ ^#0[[:space:]]+building\ with ]]; then continue; fi
                # Skip BuildKit error summary footer noise
                if [[ "$line" =~ ^------+$ ]]; then continue; fi
                if [[ "$line" =~ ^[[:space:]]*\>[[:space:]]*\[builder ]]; then continue; fi
                if [[ "$line" =~ ^Dockerfile:[0-9]+ ]]; then continue; fi
                if [[ "$line" =~ ^[[:space:]]+[0-9]+[[:space:]]+\| ]]; then continue; fi
                if [[ "$line" =~ ^\>\>\> ]]; then continue; fi
                if [[ "$line" =~ ^ERROR:[[:space:]]+failed ]]; then continue; fi
                if [[ "$line" =~ docker-desktop:// ]]; then continue; fi
                if [[ "$line" =~ View[[:space:]]+build[[:space:]]+details: ]]; then continue; fi
                
                # Strip BuildKit prefix: e.g. "#9 0.693    Compiling..." or "#9 ..."
                clean_line="$line"
                if [[ "$line" =~ ^#[0-9]+[[:space:]]+[0-9.]+[[:space:]]+(.*)$ ]]; then
                    clean_line="${BASH_REMATCH[1]}"
                elif [[ "$line" =~ ^#[0-9]+[[:space:]]+(.*)$ ]]; then
                    clean_line="${BASH_REMATCH[1]}"
                fi
                
                # Filter out structural Docker steps and BuildKit metadata
                if [[ "$clean_line" =~ ^\[[a-zA-Z0-9_-]+[[:space:]]+[0-9]+/[0-9]+\] ]]; then continue; fi
                if [[ "$clean_line" =~ ^\[internal\] ]]; then continue; fi
                if [[ "$clean_line" =~ ^(DONE|CACHED|resolve|transferring|exporting|ERROR:)([[:space:]]|$) ]]; then continue; fi
                
                # Filter out blank lines from compilation output count
                if [ -n "$(echo "$clean_line" | xargs 2>/dev/null)" ]; then
                    has_compiler_output=true
                fi
                
                compiled_logs+="$clean_line\n"
            done < "$log_file"
            
            if [ "$has_compiler_output" = true ]; then
                echo -e "\033[33m[Compiler Output]:\033[0m"
                echo -e "$compiled_logs" | sed -e '/./,$!d' | while IFS= read -r fLine; do
                    if [[ "$fLine" =~ ^error(\[|:) ]]; then
                        echo -e "\033[31m$fLine\033[0m"
                    elif [[ "$fLine" =~ ^warning(\[|:) ]]; then
                        echo -e "\033[33m$fLine\033[0m"
                    elif [[ "$fLine" =~ ^note(\[|:) ]]; then
                        echo -e "\033[36m$fLine\033[0m"
                    else
                        echo -e "\033[90m$fLine\033[0m"
                    fi
                done
            else
                # Fallback to cleaned raw logs
                echo -e "\033[33mRaw execution log:\033[0m"
                grep -Ev "docker-desktop://|View build details:|alprust_dockerfile_|Dockerfile:" "$log_file" | while IFS= read -r rLine; do
                    echo -e "\033[31m$rLine\033[0m"
                done
            fi
        else
            grep -Ev "docker-desktop://|View build details:|alprust_dockerfile_|Dockerfile:" "$log_file"
        fi
    fi
    rm -f "$log_file"
    return $status
}

# Manage temporary .dockerignore setup
docker_ignore_path="$PWD/.dockerignore"
docker_ignore_backup="$PWD/.dockerignore.alprust.bak"
temp_dist_path="$PWD/.alprust.dist.tmp"
has_docker_ignore=false

restore_docker_ignore() {
    # 1. Restore dockerignore
    if [ -f "$docker_ignore_backup" ]; then
        mv -f "$docker_ignore_backup" "$docker_ignore_path"
    elif [ "$has_docker_ignore" = false ]; then
        rm -f "$docker_ignore_path"
    fi
    # 2. Clean up temporary dist path
    if [ -d "$temp_dist_path" ]; then
        rm -rf "$temp_dist_path"
    fi
}

setup_docker_ignore() {
    # Recover from a previous crashed run
    if [ -f "$docker_ignore_backup" ]; then
        mv -f "$docker_ignore_backup" "$docker_ignore_path"
    fi

    exclusions="\n# alprust temporary exclusions\ntarget\ndist\n.git\n.alprust.*.tmp\n.env*\n*.pem\n*.key\n*.der\n*.pfx\n*.p12\nnode_modules\n.idea\n.vscode\n*.sln\n*.sln.docstate\n*.suo\n*.tmp\n*.log\n*.zip\n*.tar.gz\n"
    if [ -f "$docker_ignore_path" ]; then
        has_docker_ignore=true
        cp -f "$docker_ignore_path" "$docker_ignore_backup"
        echo -e "$exclusions" >> "$docker_ignore_path"
    else
        has_docker_ignore=false
        echo -e "$exclusions" > "$docker_ignore_path"
    fi
    trap restore_docker_ignore EXIT INT TERM
}

setup_docker_ignore

if [ "$action" == "check" ]; then
    show_header "Running syntax and type validation sweeps..." "cyan"
    buildArgs+=("-f" "-" ".")
    df="$cacheHeader\nRUN $cacheMounts cargo check \$CARGO_FLAGS"
    execute_build_with_ticker "$df" "${buildArgs[@]}"
    status=$?
    [ $status -eq 0 ] && show_header "Syntax verification passed cleanly!" "green"
    exit $status

elif [ "$action" == "test" ]; then
    show_header "Running internal unit and integration tests..." "cyan"
    buildArgs+=("-f" "-" ".")
    df="$cacheHeader\nRUN $cacheMounts cargo test \$CARGO_FLAGS"
    execute_build_with_ticker "$df" "${buildArgs[@]}"
    status=$?
    [ $status -eq 0 ] && show_header "All tests passed flawlessly!" "green"
    exit $status

elif [ "$action" == "clean" ]; then
    if [ "$all" = true ]; then
        show_header "Pruning all system-wide BuildKit cache mounts..." "yellow"
        docker builder prune --filter type=exec.cachemount -f
        exit 0
    fi
    show_header "Clearing target compilation cache for $binaryName..." "cyan"
    buildArgs+=("-f" "-" ".")
    df="FROM rust:$rustVersion\nARG BIN_NAME\nWORKDIR /app\nCOPY . .\nRUN $cacheMounts cargo clean"
    buildArgs+=("--build-arg" "BIN_NAME=$binaryName")
    execute_build_with_ticker "$df" "${buildArgs[@]}"
    status=$?
    [ $status -eq 0 ] && show_header "Compilation cache cleared cleanly!" "green"
    exit $status

else
    rm -rf ./.alprust.dist.tmp
    buildArgs+=("--build-arg" "BIN_NAME=$binaryName" "-f" "-" "-o" "./.alprust.dist.tmp" ".")
    show_header "Compiling static Alpine production binary asset pipeline..." "cyan"

    df=$(cat <<EOF
FROM rust:$rustVersion AS builder
ARG BIN_NAME
ARG CARGO_FLAGS
ARG REFRESH_CACHE=false
ARG CACHE_BYPASS
WORKDIR /app
COPY . .
RUN echo \$CACHE_BYPASS > /dev/null
RUN $cacheMounts if [ "\$REFRESH_CACHE" = "true" ]; then cargo update; fi
RUN $cacheMounts cargo test \$CARGO_FLAGS
RUN $cacheMounts cargo build --release \$CARGO_FLAGS && find /app/target -type f -name "\$BIN_NAME" -path "*/release/*" -exec cp {} /app/\$BIN_NAME \; -quit

FROM scratch
ARG BIN_NAME
COPY --from=builder /app/\$BIN_NAME /
EOF
)

    execute_build_with_ticker "$df" "${buildArgs[@]}"
    status=$?

    if [ $status -eq 0 ]; then
        # Replace the target dist directory only on success
        rm -rf ./dist
        mv -f ./.alprust.dist.tmp ./dist
        
        if [ "$action" == "run" ]; then
            show_header "Static cross-compilation pipeline executed flawlessly!" "green"
            show_header "Booting sandbox environment application loop... (Press Ctrl+C to terminate cleanly)" "cyan"
            
            hostOutputDir=$(pwd)/dist
            runArgs+=("--rm" "-it" "--init")
            
            if [ "$port" -gt 0 ]; then
                echo -e "\033[90m-------------------------------------------------------\033[0m"
                echo -e " \033[32m👉 Host OS Access URL:     http://localhost:$port\033[0m"
                echo -e " \033[33m👉 Isolated Container URL: http://0.0.0.0:$port\033[0m"
                echo -e "\033[90m-------------------------------------------------------\033[0m\n"
                runArgs+=("-p" "$port:$port" "-e" "PORT=$port")
            fi
            
            runArgs+=("-v" "$hostOutputDir:/app" "alpine" "/app/$binaryName")
            docker run "${runArgs[@]}"
        else
            show_header "Static standalone binary extracted cleanly to ./dist/$binaryName" "green"
        fi
    else
        exit $status
    fi
fi