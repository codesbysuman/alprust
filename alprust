#!/bin/bash

# 1. Route positional subcommand arguments
action="run"
if [[ "$1" =~ ^(run|check|test|build|update|init)$ ]]; then
    action="$1"
    shift
fi

# 2. Handle background self-updates instantly
if [ "$action" == "update" ]; then
    echo -e "\033[36mUpdating alprust from GitHub...\033[0m"
    SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"
    git -C "$SCRIPT_DIR" pull
    exit $?
fi

# 3. Handle project scaffolding
if [ "$action" == "init" ]; then
    echo -e "\033[36m--- alprust Scaffold Initializer ---\033[0m"
    currentFolder=$(basename "$PWD")
    
    read -p "Project Name [Default: $currentFolder]: " name
    [ -z "$name" ] && name=$currentFolder
    
    read -p "Version [Default: 0.1.0]: " version
    [ -z "$version" ] && version="0.1.0"
    
    read -p "Dependencies (e.g., tokio@1.0, serde, axum@0.7): " depsInput
    
    tomlDeps=""
    if [ ! -z "$depsInput" ]; then
        IFS=',' read -ra ADDR <<< "$depsInput"
        for dep in "${ADDR[@]}"; do
            dep=$(echo "$dep" | xargs)
            if [[ "$dep" =~ ^([^@]+)@(.+)$ ]]; then
                tomlDeps+="    ${BASH_REMATCH[1]} = \"${BASH_REMATCH[2]}\"\n"
            elif [ ! -z "$dep" ]; then
                tomlDeps+="    $dep = \"*\"\n"
            fi
        done
    fi

    cat <<EOF > Cargo.toml
[package]
name = "$name"
version = "$version"
edition = "2021"

[dependencies]
$(echo -e "$tomlDeps")
EOF

    mkdir -p src
    cat <<EOF > src/main.rs
fn main() {
    println!("Hello from alprust scaffolded project: $name!");
}
EOF

    echo -e "\n\033[32m[Success] Rust project '$name' scaffolded cleanly!\033[0m"
    exit 0
fi

# 4. Docker verification sweep
if ! docker info >/dev/null 2>&1; then
    echo "Error: Docker daemon is not running!" >&2
    exit 1
fi

# 5. Dynamic Cargo.toml context parser
if [ ! -f "Cargo.toml" ]; then
    echo "Error: No Cargo.toml found here." >&2
    exit 1
fi

binaryName=$(grep -m 1 '^name[[:space:]]*=[[:space:]]*' Cargo.toml | sed 's/.*=[[:space:]]*"\(.*\)".*/\1/')
if [ -z "$binaryName" ]; then
    echo "Error: Could not parse project name from Cargo.toml" >&2
    exit 1
fi

echo -e "\033[33mTarget Binary Detected: $binaryName\033[0m"

# 6. Parse Named Flags vs Dynamic Passthrough Arguments
offline=false
ipv4=false
port=0
passthroughFlags=()

while [[ $# -gt 0 ]]; do
    case $1 in
        -offline|--offline)
            offline=true
            shift
            ;;
        -ipv4|--ipv4)
            ipv4=true
            shift
            ;;
        -port|--port)
            port="$2"
            shift 2
            ;;
        *)
            passthroughFlags+=("$1")
            shift
            ;;
    esac
done

cargoFlagsStr="${passthroughFlags[*]}"

# 7. Auto-Handle Port Allocation Collisions
if [ "$port" -gt 0 ] && [ "$action" == "run" ]; then
    originalPort=$port
    while (echo > /dev/tcp/127.0.0.1/$port) >/dev/null 2>&1; do
        port=$((port + 1))
    done
    if [ "$port" -ne "$originalPort" ]; then
        echo -e "\033[33m[Warning] Port $originalPort is busy! Auto-shifting to open port: $port\033[0m"
    fi
fi

# 8. Core Arguments Construction
buildArgs=()
runArgs=()

if [ "$offline" = true ]; then
    echo -e "\033[35m[Mode] Strict Offline (Bypassing registry sweeps)...\033[0m"
    buildArgs+=("--pull=false")
    runArgs+=("--pull=never")
fi

if [ "$ipv4" = true ]; then
    echo -e "\033[36m[Network] Enforcing strict IPv4 fallback network stack...\033[0m"
    buildArgs+=("--network" "host")
    runArgs+=("--sysctl" "net.ipv6.conf.all.disable_ipv6=1")
fi

buildArgs+=("--build-arg" "CARGO_FLAGS=$cargoFlagsStr")

# 9. Execute Subcommand Blocks
if [ "$action" == "check" ]; then
    echo -e "\033[36mRunning 'cargo check' with hot layer registry caches...\033[0m"
    buildArgs+=("--progress=plain" "-f" "-" ".")
    df="FROM rust:alpine\nWORKDIR /app\nCOPY . .\nARG CARGO_FLAGS\nRUN --mount=type=cache,target=/usr/local/cargo/registry/db --mount=type=cache,target=/usr/local/cargo/registry/cache --mount=type=cache,target=/usr/local/cargo/git/db cargo check \$CARGO_FLAGS"
    echo -e "$df" | docker build "${buildArgs[@]}"
    exit $?

elif [ "$action" == "test" ]; then
    echo -e "\033[36mRunning 'cargo test' with hot layer registry caches...\033[0m"
    buildArgs+=("--progress=plain" "-f" "-" ".")
    df="FROM rust:alpine\nWORKDIR /app\nCOPY . .\nARG CARGO_FLAGS\nRUN --mount=type=cache,target=/usr/local/cargo/registry/db --mount=type=cache,target=/usr/local/cargo/registry/cache --mount=type=cache,target=/usr/local/cargo/git/db cargo test \$CARGO_FLAGS"
    echo -e "$df" | docker build "${buildArgs[@]}"
    exit $?

else
    buildArgs+=("--build-arg" "BIN_NAME=$binaryName" "-f" "-" "-o" "./output" ".")
    echo -e "\033[36mCompiling static Alpine binary with cache mounts active...\033[0m"
    rm -rf ./output

    df=$(cat <<EOF
FROM rust:alpine AS builder
ARG BIN_NAME
ARG CARGO_FLAGS
WORKDIR /app
COPY . .
RUN --mount=type=cache,target=/usr/local/cargo/registry/db --mount=type=cache,target=/usr/local/cargo/registry/cache --mount=type=cache,target=/usr/local/cargo/git/db cargo test \$CARGO_FLAGS
RUN --mount=type=cache,target=/usr/local/cargo/registry/db --mount=type=cache,target=/usr/local/cargo/registry/cache --mount=type=cache,target=/usr/local/cargo/git/db cargo build --release --target x86_64-unknown-linux-musl \$CARGO_FLAGS

FROM scratch
ARG BIN_NAME
COPY --from=builder /app/target/x86_64-unknown-linux-musl/release/\$BIN_NAME /
EOF
)

    echo "$df" | docker build "${buildArgs[@]}"

    if [ $? -eq 0 ] && [ "$action" == "run" ]; then
        echo -e "\n\033[32m[Success] Static binary compiled perfectly!\033[0m"
        echo -e "\033[36mBooting your application inside Alpine environment...\033[0m"
        
        hostOutputDir=$(pwd)/output
        runArgs+=("--rm" "-it" "--init")
        
        if [ "$port" -gt 0 ]; then
            echo -e "\n\033[90m[Uniform Network Link Setup Active]\033[0m"
            echo -e "\033[32m👉 Host Machine Access URL: http://localhost:$port\033[0m"
            echo -e "\033[33m👉 Internal Container URL:  http://0.0.0.0:$port\033[0m"
            runArgs+=("-p" "$port:$port" "-e" "PORT=$port")
        fi
        
        runArgs+=("-v" "$hostOutputDir:/app" "alpine" "/app/$binaryName")
        docker run "${runArgs[@]}"
    elif [ $? -eq 0 ]; then
        echo -e "\n\033[32m[Success] Static binary saved cleanly to ./output/$binaryName\033[0m"
    else
        echo "Error: Build execution failed inside the pipeline container." >&2
        exit 1
    fi
fi