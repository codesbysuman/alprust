#!/bin/bash

show_header() {
    local msg="$1"
    local color="$2"
    case "$color" in
        "green")  echo -e "\n\033[32m[alprust] $msg\033[0m" ;;
        "yellow") echo -e "\n\033[33m[alprust] $msg\033[0m" ;;
        "magenta")echo -e "\n\033[35m[alprust] $msg\033[0m" ;;
        *)        echo -e "\n\033[36m[alprust] $msg\033[0m" ;;
    esac
}

action="run"
if [[ "$1" =~ ^(run|check|test|build|update|init|help)$ ]]; then
    action="$1"
    shift
fi

if [ "$action" == "help" ]; then
    cat << 'EOF'

=======================================================================
   alprust CLI 🚀 - Ultra-lean Alpine Linux Compilation Suite
=======================================================================
Created and maintained by codesbysuman.

Usage:
  alprust [subcommand] [flags] [passthrough-cargo-options]

Subcommands:
  init      Scaffold a brand-new Rust binary workspace from scratch
  check     Verify syntax & type safety using global cached crates
  test      Run the full workspace unit test suite inside Alpine
  build     Compile and export optimized static musl binaries
  run       (Default) Build, test, and instantly execute inside sandbox
  update    Pull the latest engine upgrades natively from GitHub
  help      Display this unified architecture help documentation

Core Tool Modifiers & Flags:
  -port <int>  Map internal container network bridges out to host OS
  -offline     Strict air-gap execution. Disconnects internet bridges
  -refresh     Safely pull the newest crate versions into the central cache
  -ipv4        Enforce IPv4 stacks (Fixes WSL2 network freezing bugs)

=======================================================================
EOF
    exit 0
fi

if [ "$action" == "update" ]; then
    show_header "Updating engine source files from GitHub..." "cyan"
    SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"
    git -C "$SCRIPT_DIR" pull
    exit $?
fi

if [ "$action" == "init" ]; then
    echo -e "\033[36m\n=========================================="
    echo -e "   alprust Project Scaffolding Engine     "
    echo -e "==========================================\033[0m"
    currentFolder=$(basename "$PWD")
    
    read -p "📦 Project Name [Default: $currentFolder]: " name
    [ -z "$name" ] && name=$currentFolder
    
    read -p "🏷️ Version [Default: 0.1.0]: " version
    [ -z "$version" ] && version="0.1.0"

    read -p "🦀 Rust Edition (e.g., 2021, 2024) [Default: 2021]: " edition
    [ -z "$edition" ] && edition="2021"
    
    read -p "⚙️ Dependencies (comma separated, e.g., tokio@1, serde): " depsInput
    
    tomlDeps=""
    if [ ! -z "$depsInput" ]; then
        IFS=',' read -ra ADDR <<< "$depsInput"
        for dep in "${ADDR[@]}"; do
            dep=$(echo "$dep" | xargs)
            if [[ "$dep" =~ ^([^@]+)@(.+)$ ]]; then
                tomlDeps+="    ${BASH_REMATCH[1]} = \"${BASH_REMATCH[2]}\"\n"
            elif [ ! -z "$dep" ]; then
                tomlDeps+="    $dep = \"*\"\n"
            fi
        done
    fi

    cat <<EOF > Cargo.toml
[package]
name = "$name"
version = "$version"
edition = "$edition"

[dependencies]
$(echo -e "$tomlDeps")
EOF

    mkdir -p src
    cat <<EOF > src/main.rs
fn main() {
    println!("Hello from alprust scaffolded project: $name (Edition $edition)!");
}
EOF

    echo -e "\n\033[32m✨ Success! Rust project '$name' scaffolded cleanly!\033[0m"
    exit 0
fi

if ! docker info >/dev/null 2>&1; then
    echo -e "\033[31m[Error] Docker daemon is not running! Initialize your engine first.\033[0m" >&2
    exit 1
fi

if [ ! -f "Cargo.toml" ]; then
    echo -e "\033[31m[Error] No Cargo.toml discovered. Ensure your execution path matches a Rust root directory!\033[0m" >&2
    exit 1
fi

binaryName=$(grep -m 1 '^name[[:space:]]*=[[:space:]]*' Cargo.toml | sed 's/.*=[[:space:]]*"\(.*\)".*/\1/')
if [ -z "$binaryName" ]; then
    echo -e "\033[31m[Error] Unable to isolate package structural definitions inside Cargo.toml.\033[0m" >&2
    exit 1
fi

echo -e "\033[90mTarget Workspace Detected: \033[0m\033[33m$binaryName\033[0m"

offline=false
ipv4=false
refresh=false
port=0
passthroughFlags=()

while [[ $# -gt 0 ]]; do
    case $1 in
        -offline|--offline) offline=true; shift ;;
        -ipv4|--ipv4)       ipv4=true; shift ;;
        -refresh|--refresh) refresh=true; shift ;;
        -port|--port)       port="$2"; shift 2 ;;
        *)                  passthroughFlags+=("$1"); shift ;;
    esac
done

cargoFlagsStr="${passthroughFlags[*]}"

if [ "$port" -gt 0 ] && [ "$action" == "run" ]; then
    originalPort=$port
    while (echo > /dev/tcp/127.0.0.1/$port) >/dev/null 2>&1; do
        port=$((port + 1))
    done
    if [ "$port" -ne "$originalPort" ]; then
        echo -e "\033[33m[Warning] Port $originalPort is currently busy! Auto-shifting link to open slot: $port\033[0m"
    fi
fi

buildArgs=("--progress=quiet") 
runArgs=()

if [ "$offline" = true ]; then
    show_header "Strict Air-Gap Mode Active. Virtual networks severed." "magenta"
    buildArgs+=("--network" "none" "--pull=false")
    runArgs+=("--pull=never")
fi

if [ "$ipv4" = true ]; then
    show_header "Enforcing defensive IPv4 host mapping fallback layers..." "cyan"
    buildArgs+=("--network" "host")
    runArgs+=("--sysctl" "net.ipv6.conf.all.disable_ipv6=1")
fi

buildArgs+=("--build-arg" "CARGO_FLAGS=$cargoFlagsStr")
if [ "$refresh" = true ]; then
    show_header "Atomic refresh triggered. Scanning upstream for newer package variations..." "yellow"
    buildArgs+=("--build-arg" "REFRESH_CACHE=true")
else
    buildArgs+=("--build-arg" "REFRESH_CACHE=false")
fi

cacheHeader="FROM rust:alpine AS base\nARG CARGO_FLAGS\nARG REFRESH_CACHE=false\nWORKDIR /app\nCOPY . .\nRUN --mount=type=cache,id=alprust-registry-db,target=/usr/local/cargo/registry/db --mount=type=cache,id=alprust-registry-cache,target=/usr/local/cargo/registry/cache --mount=type=cache,id=alprust-git-db,target=/usr/local/cargo/git/db if [ \"\$REFRESH_CACHE\" = \"true\" ]; then cargo update; fi"

if [ "$action" == "check" ]; then
    show_header "Running syntax and type validation sweeps..." "cyan"
    buildArgs+=("-f" "-" ".")
    df="$cacheHeader\nRUN --mount=type=cache,id=alprust-registry-db,target=/usr/local/cargo/registry/db --mount=type=cache,id=alprust-registry-cache,target=/usr/local/cargo/registry/cache --mount=type=cache,id=alprust-git-db,target=/usr/local/cargo/git/db cargo check \$CARGO_FLAGS"
    echo -e "$df" | docker build "${buildArgs[@]}"
    [ $? -eq 0 ] && show_header "Syntax verification passed cleanly!" "green"
    exit $?

elif [ "$action" == "test" ]; then
    show_header "Running internal unit and integration tests..." "cyan"
    buildArgs+=("-f" "-" ".")
    df="$cacheHeader\nRUN --mount=type=cache,id=alprust-registry-db,target=/usr/local/cargo/registry/db --mount=type=cache,id=alprust-registry-cache,target=/usr/local/cargo/registry/cache --mount=type=cache,id=alprust-git-db,target=/usr/local/cargo/git/db cargo test \$CARGO_FLAGS"
    echo -e "$df" | docker build "${buildArgs[@]}"
    [ $? -eq 0 ] && show_header "All tests passed flawlessly!" "green"
    exit $?

else
    buildArgs+=("--build-arg" "BIN_NAME=$binaryName" "-f" "-" "-o" "./output" ".")
    show_header "Compiling static Alpine production binary asset pipeline..." "cyan"
    rm -rf ./output

    df=$(cat <<EOF
FROM rust:alpine AS builder
ARG BIN_NAME
ARG CARGO_FLAGS
ARG REFRESH_CACHE=false
WORKDIR /app
COPY . .
RUN --mount=type=cache,id=alprust-registry-db,target=/usr/local/cargo/registry/db --mount=type=cache,id=alprust-registry-cache,target=/usr/local/cargo/registry/cache --mount=type=cache,id=alprust-git-db,target=/usr/local/cargo/git/db if [ "\$REFRESH_CACHE" = "true" ]; then cargo update; fi
RUN --mount=type=cache,id=alprust-registry-db,target=/usr/local/cargo/registry/db --mount=type=cache,id=alprust-registry-cache,target=/usr/local/cargo/registry/cache --mount=type=cache,id=alprust-git-db,target=/usr/local/cargo/git/db cargo test \$CARGO_FLAGS
RUN --mount=type=cache,id=alprust-registry-db,target=/usr/local/cargo/registry/db --mount=type=cache,id=alprust-registry-cache,target=/usr/local/cargo/registry/cache --mount=type=cache,id=alprust-git-db,target=/usr/local/cargo/git/db cargo build --release --target x86_64-unknown-linux-musl \$CARGO_FLAGS

FROM scratch
ARG BIN_NAME
COPY --from=builder /app/target/x86_64-unknown-linux-musl/release/\$BIN_NAME /
EOF
)

    echo "$df" | docker build "${buildArgs[@]}"

    if [ $? -eq 0 ] && [ "$action" == "run" ]; then
        show_header "Static cross-compilation pipeline executed flawlessly!" "green"
        show_header "Booting sandbox environment application loop... (Press Ctrl+C to terminate cleanly)" "cyan"
        
        hostOutputDir=$(pwd)/output
        runArgs+=("--rm" "-it" "--init")
        
        if [ "$port" -gt 0 ]; then
            echo -e "\n\033[90m-------------------------------------------------------\033[0m"
            echo -e " \033[32m👉 Host OS Access URL:     http://localhost:$port\033[0m"
            echo -e " \033[33m👉 Isolated Container URL: http://0.0.0.0:$port\033[0m"
            echo -e "\033[90m-------------------------------------------------------\033[0m\n"
            runArgs+=("-p" "$port:$port" "-e" "PORT=$port")
        fi
        
        runArgs+=("-v" "$hostOutputDir:/app" "alpine" "/app/$binaryName")
        docker run "${runArgs[@]}"
    elif [ $? -eq 0 ]; then
        show_header "Static standalone binary extracted cleanly to ./output/$binaryName" "green"
    else
        echo -e "\033[31m[Error] Build pipeline halted due to code compilation failures.\033[0m" >&2
        exit 1
    fi
fi