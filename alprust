#!/bin/bash

# 1. Quick sanity check for Docker
if ! docker info >/dev/null 2>&1; then
    echo "Error: Docker daemon is not running!" >&2
    exit 1
fi

# 2. Extract binary name dynamically
if [ ! -f "Cargo.toml" ]; then
    echo "Error: No Cargo.toml found here." >&2
    exit 1
fi

binaryName=$(grep -m 1 '^name[[:space:]]*=[[:space:]]*' Cargo.toml | sed 's/.*=[[:space:]]*"\(.*\)".*/\1/')
if [ -z "$binaryName" ]; then
    echo "Error: Could not parse project name from Cargo.toml" >&2
    exit 1
fi

echo -e "\033[33mTarget Binary Detected: $binaryName\033[0m"

# 3. Parse flags
offline=false
for arg in "$@"; do
    if [ "$arg" == "-offline" ] || [ "$arg" == "--offline" ]; then
        offline=true
    fi
done

buildArgs=()
runArgs=()

if [ "$offline" = true ]; then
    echo -e "\033[35m[Mode] Strict Offline (Using local cache)...\033[0m"
    buildArgs+=("--pull=false")
    runArgs+=("--pull=never")
fi

buildArgs+=("--build-arg" "BIN_NAME=$binaryName" "-f" "-" "-o" "./output" ".")

echo -e "\033[36mCompiling and extracting static Alpine binary...\033[0m"
rm -rf ./output

# 4. In-Memory Dockerfile pipeline via Bash EOF stream
dockerfileContent=$(cat <<EOF
FROM rust:alpine AS builder
ARG BIN_NAME
WORKDIR /app
COPY . .
RUN cargo test
RUN cargo build --release --target x86_64-unknown-linux-musl

FROM scratch
ARG BIN_NAME
COPY --from=builder /app/target/x86_64-unknown-linux-musl/release/\$BIN_NAME /
EOF
)

# Feed build array natively via stdin
echo "$dockerfileContent" | docker build "${buildArgs[@]}"

# 5. Boot Runtime Layer
if [ $? -eq 0 ]; then
    echo -e "\n\033[32m[Success] Static binary compiled perfectly!\033[0m"
    echo -e "\033[36mBooting your application inside Alpine environment...\033[0m"
    
    hostOutputDir=$(pwd)/output
    runArgs+=("--rm" "-it" "-p" "8080:8080" "-v" "$hostOutputDir:/app" "alpine" "/app/$binaryName")
    
    docker run "${runArgs[@]}"
else
    echo "Error: Build execution failed inside the pipeline container." >&2
    exit 1
fi